4\" fill=\"none\" stroke=\"#B87533\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 12c-1.6-2.1-3.1-3.2-5-3.2a3.2 3.2 0 1 0 0 6.4c1.9 0 3.4-1.1 5-3.2zm0 0c1.6 2.1 3.1 3.2 5 3.2a3.2 3.2 0 1 0 0-6.4c-1.9 0-3.4 1.1-5 3.2z\"/></svg>\n    <span>Accès à vie</span>\n  </div>\n  <div class=\"sw-trust__i\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#B87533\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/><path d=\"M9 11.5l2 2 4-4\"/></svg>\n    <span>Satisfait ou remboursé</span>\n  </div>\n  <div class=\"sw-trust__i\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#B87533\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"10\" rx=\"2\"/><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"/></svg>\n    <span>Paiement sécurisé</span>\n  </div>\n</div>\n<style>\n.sw-trust{\n  display:flex; flex-wrap:wrap; gap:12px;\n  margin:16px 0; padding:14px 12px;\n  border:1px solid rgba(184,117,51,.30);\n  border-radius:12px;\n  background:rgba(184,117,51,.04);\n}\n.sw-trust__i{ flex:1 1 130px; display:flex; align-items:center; gap:9px; }\n.sw-trust__i svg{ width:22px; height:22px; flex:none; }\n.sw-trust__i span{ font-size:13.5px; line-height:1.25; font-weight:500; }\n</style>"}}},"block_order":["price_BYX3MC","text_6jpYpG","liquid_9mNFmC","spd_split_payment_app_installment_widget_LeWQpV","buy_buttons_ykgbBb","liquid_QGPQKW","liquid_iHhQTc"],"settings":{"enable_sticky_info":false,"media_size":60,"gallery_layout":"thumbnail","thumbnail_position":"beside","image_ratio":"adapt","image_zoom":"lightbox","hide_variants":false,"enable_video_autoplay":true,"enable_video_looping":true,"mobile_layout":"full_width","image_ratio_mobile":"adapt","mobile_thumbnail":false,"padding_top":88,"padding_bottom":88,"divider":false,"full_width":true,"rounded":false}},"custom_section_7aHyAe":{"type":"custom-section","blocks":{"text_rt8mUH":{"type":"text","name":"t:blocks.text.name","settings":{"text":"<p>Si tu possèdes <strong>Ableton</strong>, que ce soit depuis peu ou depuis longtemps, tu t’es sûrement déjà retrouvé dans ce genre de situation.</p><p>Tu utilises <strong>Ableton</strong>… mais sans vraiment le <strong>maîtriser</strong>. Tu produis un peu, tu termines quelques morceaux, mais globalement tu bricoles. Tu ne maîtrises pas totalement l’interface, tu ne comprends pas encore tous les <strong>effets</strong>, et beaucoup de fonctionnalités te restent inconnues.</p><p>Tu t’appuies sur des <strong>habitudes fragiles</strong>. Tu navigues à l’aveugle dans la bibliothèque, tu charges des presets, tu tournes quelques potards, mais tu sens bien que ton <strong>workflow</strong> n’est pas optimal. Découvrir les méthodes et habitudes d’un professionnel pourrait te débloquer dans de nombreuses situations, et te permettre de vraiment libérer ta créativité.</p><p>Et tu sous-exploites ce que tu possèdes déjà. Comme beaucoup, tu te laisses tenter par de nouveaux <strong>plug-ins</strong>, des synthés aux belles interfaces… alors qu’<strong>Ableton</strong> intègre déjà une armée d’outils <strong>puissants</strong>, parfaitement adaptés à son architecture, capables d’ouvrir de nouvelles approches et techniques sonores.</p><p>C’est exactement dans ce but que j’ai créé ce bundle. Avec plus de <strong>17 heures de contenu</strong>, il contient tout ce qu’il faut pour t’aider à vraiment <strong>maîtriser Ableton Live</strong>, construire un workflow plus <strong>solide</strong>, et exploiter enfin tout le potentiel du logiciel que tu as déjà sous la main.</p>","text_font":"body","text_size":"text-base","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"width":"fit-content","custom_width":100,"alignment":"left","width_mobile":"fit-content","custom_width_mobile":100,"effects":"none","highlighted_text":"text","highlighted_scribble":"circle"},"blocks":{}},"spacer_yTHK93":{"type":"spacer","name":"t:blocks.spacer.name","settings":{"size":"percent","percent_size":100,"pixel_size":120,"custom_mobile_size":false,"size_mobile":"percent","percent_size_mobile":100,"pixel_size_mobile":120},"blocks":{}},"custom_liquid_3EeqtJ":{"type":"custom-liquid","name":"t:sections.custom-liquid.name","settings":{"liquid":"<h2 style=\"\n  font-size: 18px;\n  font-weight: bold;\n\">\n  CE QUE TU VAS APPRENDRE : \n</h2>"},"blocks":{}},"text_e3datH":{"type":"text","name":"t:blocks.text.name","settings":{"text":"<p>• <strong>Maîtriser totalement Ableton Live</strong>, de l’interface au routing avancé<br/>• Comprendre en profondeur <strong>tous les effets natifs d’Ableton Live</strong> (EQ, compression, saturation, spatialisation…)<br/>• Exploiter intelligemment <strong>Wavetable, Operator, Analog, Drift et les samplers natifs</strong><br/>• Construire des <strong>Audio Effect Racks puissants et modulables</strong><br/>• Développer un <strong>workflow professionnel rapide et structuré</strong><br/>• Arrêter de dépendre de plug-ins externes en maîtrisant <strong>100 % des outils natifs d’Ableton Live</strong><br/>• Comprendre la logique du <strong>gain staging, des traitements dynamiques et de la cohérence spectrale</strong><br/>• Créer tes propres sons grâce à une vraie maîtrise du <strong>sound design dans Ableton</strong><br/>• Améliorer la qualité de tes mixes <strong>dès la phase de production</strong><br/>• Utiliser les <strong>automations, modulations et mappings avancés</strong><br/>• Concevoir des morceaux complets avec une <strong>vision claire et maîtrisée</strong><br/>• Développer une <strong>identité sonore forte</strong> en façonnant tes sons dès leur création</p>","text_font":"body","text_size":"text-base","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"width":"fit-content","custom_width":100,"alignment":"left","width_mobile":"fit-content","custom_width_mobile":100,"effects":"none","highlighted_text":"text","highlighted_scribble":"circle"},"blocks":{}},"spacer_dE7nFG":{"type":"spacer","name":"t:blocks.spacer.name","settings":{"size":"percent","percent_size":100,"pixel_size":120,"custom_mobile_size":false,"size_mobile":"percent","percent_size_mobile":100,"pixel_size_mobile":120},"blocks":{}},"custom_liquid_PJJyzK":{"type":"custom-liquid","name":"t:sections.custom-liquid.name","settings":{"liquid":"<h2 style=\"\n  font-size: 18px;\n  font-weight: bold;\n\">\n  POUR TOI SI \n</h2>"},"blocks":{}},"text_d4TL9i":{"type":"text","name":"t:blocks.text.name","settings":{"text":"<p>✓ Tu veux apprendre Ableton Live des premiers pas <strong>à l'autonomie complète</strong><br/>✓ Tu veux <strong>maîtriser Ableton Live à 100 %</strong>, pas juste “te débrouiller”<br/>✓ Tu veux comprendre et exploiter <strong>tous les outils d’un des meilleurs DAWs du marché</strong><br/>✓ Tu refuses de rester limité par une méconnaissance du logiciel<br/>✓ Tu veux produire avec <strong>puissance, fluidité et contrôle total</strong><br/>✓ Tu veux arrêter de cliquer au hasard et commencer à <strong>prendre des décisions conscientes</strong><br/>✓ Tu veux exploiter chaque effet, chaque instrument, <strong>chaque possibilité d’Ableton Live</strong><br/></p>","text_font":"body","text_size":"text-base","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"width":"fit-content","custom_width":100,"alignment":"left","width_mobile":"fit-content","custom_width_mobile":100,"effects":"none","highlighted_text":"text","highlighted_scribble":"circle"},"blocks":{}},"spacer_Dhxx8e":{"type":"spacer","name":"t:blocks.spacer.name","settings":{"size":"percent","percent_size":100,"pixel_size":120,"custom_mobile_size":false,"size_mobile":"percent","percent_size_mobile":100,"pixel_size_mobile":120},"blocks":{}},"custom_liquid_jGeRzm":{"type":"custom-liquid","name":"t:sections.custom-liquid.name",