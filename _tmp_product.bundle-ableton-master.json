i</p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["heading_U6BcM6","text_DWBj6d"],"disabled":true,"name":"t:sections.rich-text.name","settings":{"text_alignment":"center","text_alignment_mobile":"center","heading":"","heading_size":"title-md","heading_alignment":"text-left md:items-end md:flex-row","heading_width":"small","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":88,"padding_bottom":88,"divider":false,"narrow":true,"rounded":false}},"testimonials_8ERKtF":{"type":"testimonials","blocks":{"testimonial_48NWLm":{"type":"testimonial","settings":{"icon":"quote","text":"<p>Add customer reviews and testimonials to showcase your store’s happy customers.</p>","author":"Author's name","author_info":"","author_url":"","image_ratio":"rounded","image_height":30,"highlighted_text":"none","highlighted_scribble":"circle"}},"testimonial_4qmgQm":{"type":"testimonial","settings":{"icon":"quote","text":"<p>Add customer reviews and testimonials to showcase your store’s happy customers.</p>","author":"Author's name","author_info":"","author_url":"","image_ratio":"rounded","image_height":30,"highlighted_text":"none","highlighted_scribble":"circle"}},"testimonial_krhg8P":{"type":"testimonial","settings":{"icon":"quote","text":"<p>Add customer reviews and testimonials to showcase your store’s happy customers.</p>","author":"Author's name","author_info":"","author_url":"","image_ratio":"rounded","image_height":30,"highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["testimonial_48NWLm","testimonial_4qmgQm","testimonial_krhg8P"],"disabled":true,"name":"t:sections.testimonials.name","settings":{"heading":"","heading_size":"title-md","heading_alignment":"text-center md:items-center","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":0,"padding_bottom":88,"divider":false,"rounded":false}},"image_with_text_yJHbyt":{"type":"image-with-text","blocks":{"heading_zKDTNi":{"type":"heading","settings":{"heading":"<strong>Ton formateur</strong>","heading_size":"title-md","heading_tag":"h2","highlighted_text":"half_text","highlighted_scribble":"circle","highlighted_reveal":true}},"text_ydDD6A":{"type":"text","settings":{"text":"<p>Je suis <strong>Swander</strong> — musicien, compositeur et ingénieur du son depuis <strong>plus de dix ans.</strong></p><p>J'ai commencé à produire sur Ableton Live en 2014, je l'ai<strong> utilisé dans toutes les situations possibles </strong>: sound design, mixage, composition...</p><p>Et depuis 2023, je me suis donné pour mission d’<strong>aider les producteurs à progresser</strong> pour pouvoir s’exprimer librement.<br/><br/>Beaucoup d'entre vous produisent avec un workflow sous optimisé, en sous exploitant leur logiciel ou en <strong>passant complètement à côté de certains plug-ins...</strong></p><p><strong>Cette sous-utilisation </strong>amène de la lenteur, des erreurs techniques, de la perte d'inspiration : pour un musicien, il n'y a <strong>rien de pire</strong> que de mettre des contraintes entre son esprit créatif et la réalité.</p><p>Ce <strong>bundle exclusif</strong> te permet de <strong>reprendre totalement le contrôle sur ton logiciel.</strong><br/><br/>Avec plus de <strong>15 heures de contenu</strong>, c’est un <strong>investissement concret sur toi-même et sur ta façon de produire.</strong></p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"underline","highlighted_scribble":"circle"}},"liquid_7czmNh":{"type":"liquid","settings":{"liquid":"{%- assign p = all_products['ableton-master'] -%}\n{%- if p -%}\n\n  {%- assign v = p.selected_or_first_available_variant -%}\n\n  {%- assign mo = nil -%}\n\n  {%- if v and v.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = v.metafields.custom.buy_button.value -%}\n  {%- elsif p.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = p.metafields.custom.buy_button.value -%}\n  {%- endif -%}\n\n  {%- if mo -%}\n    {%- render 'meta-buy-button', mo: mo, force_label: 'Commencer la formation' -%}\n  {%- else -%}\n    <!-- buy_button introuvable (ni sur la variante, ni sur le produit) -->\n  {%- endif -%}\n\n{%- else -%}\n  <!-- Produit introuvable -->\n{%- endif -%}"}}},"block_order":["heading_zKDTNi","text_ydDD6A","liquid_7czmNh"],"custom_css":["/* Stop le zoom \"artificiel\" du thème */.image-with-text img,.image-with-text__media img,.image-with-text .media img {transform: none !important;}"],"name":"t:sections.image-with-text.name","settings":{"image":"shopify://shop_images/website_assets_qui_suis_je_formation.gif","image_height":"adapt","image_width":"small","layout":"text_first","text_alignment":"left","content_position":"align-self-center","image_height_mobile":"auto","text_alignment_mobile":"left","color_text":"","color_background":"#1e1e1e","gradient_background":"","color_background_2":"","gradient_background_2":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":88,"padding_bottom":88,"divider":false,"full_width":false,"rounded":true,"enable_parallax":true,"parallax_direction":"vertical"}},"faq_BgGDJU":{"type":"faq","blocks":{"question_NtWJN7":{"type":"question","settings":{"title":"Cette formation permet-elle vraiment de maîtriser Ableton Live à 100 % ?","text":"<p>Oui. Ableton Master est conçu pour t'aider à comprendre et exploiter tous les outils natifs d'Ableton Live : interface, routing, effets, instruments, automations et workflow. L'objectif est de ne plus subir le logiciel mais de le maîtriser complètement.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_Pcy9aA":{"type":"question","settings":{"title":"Est-ce adapté si je débute sur Ableton Live ?","text":"<p>Oui. Le module Dompter Ableton une bonne fois pour toutes pose les bases complètes d'Ableton Live : navigation, organisation, gestion des pistes, export, etc. Tu peux donc commencer même si tu n'as jamais utilisé Ableton Live sérieusement.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_VPQae6":{"type":"question","settings":{"title":"Et si j'utilise déjà Ableton Live depuis longtemps ?","text":"<p>Alors ce bundle est probablement encore plus intéressant pour toi. Beaucoup de producteurs utilisent Ableton Live depuis des années sans exploiter réellement ses effets natifs, ses instruments ou ses possibilités avancées. Cette formation comble précisément ces angles morts.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_PLtGNA":{"type":"question","settings":{"title":"Est-ce que je vais apprendre à utiliser les effets natifs d'Ableton Live ?","text":"<p>Oui. La formation Ableton Effects décortique en profondeur chaque effet natif d'Ableton Live : EQ, compression, saturation, spatialisation, traitements créatifs et routings avancés.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_DYJRM3":{"type":"question","settings":{"title":"Est-ce que je vais apprendre le sound design dans Ableton Live ?","text":"<p>Oui. La formation Ableton Instruments te permet de maîtriser les synthétiseurs et samplers natifs d'Ableton Live comme Wavetable, Operator, Analog ou Drift. Tu apprends à créer tes propres sons directement dans le logiciel.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_XcdTWT":{"type":"question","settings":{"title":"Faut-il la dernière version d'Ableton Live ?","text":"<p>Non. La majorité des outils étudiés sont présents depuis plusieurs versions d'Ableton Live. Si certaines nouveautés spécifiques apparaissent, elles sont précisées.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_rCPALX":{"type":"question","settings":{"title":"Est-ce que cette formation fonctionne quel que soit mon style musical ?","text":"<p>Oui. Ableton Live est un DAW polyvalent utilisé en rap, house, techno, pop, ambient et bien d'autres styles. Les principes enseignés s'appliquent à tous les genres.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_XQfkfn":{"type":"question","settings":{"title":"Combien de temps ai-je accès à la formation Ableton Live ?","text":"<p>L'accès est à vie. Une fois inscrit, tu peux revoir les modules autant de fois que nécessaire.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_8kjwQm":{"type":"question","settings":{"title":"En quoi cette formation est différente des tutoriels gratuits sur Ableton Live ?","text":"<p>Les tutoriels gratuits sont souvent fragmentés et sans progression logique. Ici, tu suis un programme structuré qui couvre l'ensemble d'Ableton Live pour construire une maîtrise cohérente et durable.</p>","highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["question_NtWJN7","question_Pcy9aA","question_VPQae6","question_PLtGNA","question_DYJRM3","question_XcdTWT","question_rCPALX","question_XQfkfn","question_8kjwQm"],"custom_css":[],"name":"t:sections.faq.name","settings":{"style":"with-background","heading":"Questions fréquentes","heading_size":"title-md","heading_alignment":"text-left md:items-end md:flex-row","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","color_overlay":"#ffffff","overlay_opacity":4,"padding_top":0,"padding_bottom":0,"divider":false,"narrow":false,"rounded":false}},"image_with_text_overlay_dnpBHr":{"type":"image-with-text-overlay","blocks":{"heading_pjbK3T":{"type":"heading","settings":{"heading":"<strong>Prêt à maîtriser Ableton Live </strong><em><strong>une bonne fois pour toutes ?</strong></em>","heading_size":"title-sm","heading_tag":"p","highlighted_text":"underline","highlighted_scribble":"circle","highlighted_reveal":false}},"text_7W3cwK":{"type":"text","settings":{"text":"<p>Ableton Master, c'est ta notice d'utilisation sous stéroïdes pour apprendre à connaître ton logiciel <strong>dans ses moindres recoins.</strong></p><p>Ce bundle te donne un accès à vie à tout le savoir nécessaire pour faire du son en en pleine possession de tes moyens <strong>en maîtrisant totalement Ableton Live.</strong></p><p>Si tu possèdes déjà Ableton Instruments ou Ableton Effects, une réduction automatique de 100 € s’applique au moment du paiement.</p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"scribble","highlighted_scribble":"basic-underline"}},"liquid_wExkQQ":{"type":"liquid","settings":{"liquid":"{%- assign v = product.selected_or_first_available_variant -%}\n\n<p class=\"heading\" style=\"display:flex; gap:12px; align-items:baseline; font-size:clamp(24px, 5vw, 40px);\">\n  {%- if v.compare_at_price > v.price -%}\n    <s style=\"color:#B87533; opacity:0.9;\">\n      {{ v.compare_at_price | money }}\n    </s>\n  {%- endif -%}\n  <span>\n    {{ v.price | money }}\n  </span>\n</p>"}},"text_RUQmwT":{"type":"text","settings":{"text":"<p><strong>Paiement en plusieurs  fois disponible ⸱  Accès </strong><em><strong>  à vie</strong></em></p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"underline","highlighted_scribble":"circle"}},"liquid_7fmcba":{"type":"liquid","settings":{"liquid":"{%- assign v = product.selected_or_first_available_variant -%}\n\n{%- if v.compare_at_price and v.compare_at_price > v.price -%}\n  {%- assign savings_cents = v.compare_at_price | minus: v.price -%}\n  <p class=\"sw-savings\">\n    {{ savings_cents | money_with_currency | replace: 'EUR', '' | strip }} euros d'économies\n  </p>\n{%- endif -%}"}},"liquid_pP9EHX":{"type":"liquid","settings":{"liquid":"{%- assign p = all_products['ableton-master'] -%}\n{%- if p -%}\n\n  {%- assign v = p.selected_or_first_available_variant -%}\n\n  {%- assign mo = nil -%}\n\n  {%- if v and v.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = v.metafields.custom.buy_button.value -%}\n  {%- elsif p.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = p.metafields.custom.buy_button.value -%}\n  {%- endif -%}\n\n  {%- if mo -%}\n    {%- render 'meta-buy-button', mo: mo, force_label: 'Commencer la formation' -%}\n  {%- else -%}\n    <!-- buy_button introuvable (ni sur la variante, ni sur le produit) -->\n  {%- endif -%}\n\n{%- else -%}\n  <!-- Produit introuvable -->\n{%- endif -%}"}}},"block_order":["heading_pjbK3T","text_7W3cwK","liquid_wExkQQ","text_RUQmwT","liquid_7fmcba","liquid_pP9EHX"],"name":"t:sections.image-with-text-overlay.name","settings":{"transparent_header":false,"image":"shopify://shop_i