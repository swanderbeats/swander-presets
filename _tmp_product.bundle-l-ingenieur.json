88,"padding_bottom":88,"divider":false,"narrow":true,"rounded":false}},"testimonials_8ERKtF":{"type":"testimonials","blocks":{"testimonial_48NWLm":{"type":"testimonial","settings":{"icon":"quote","text":"<p>Add customer reviews and testimonials to showcase your store’s happy customers.</p>","author":"Author's name","author_info":"","author_url":"","image_ratio":"rounded","image_height":30,"highlighted_text":"none","highlighted_scribble":"circle"}},"testimonial_4qmgQm":{"type":"testimonial","settings":{"icon":"quote","text":"<p>Add customer reviews and testimonials to showcase your store’s happy customers.</p>","author":"Author's name","author_info":"","author_url":"","image_ratio":"rounded","image_height":30,"highlighted_text":"none","highlighted_scribble":"circle"}},"testimonial_krhg8P":{"type":"testimonial","settings":{"icon":"quote","text":"<p>Add customer reviews and testimonials to showcase your store’s happy customers.</p>","author":"Author's name","author_info":"","author_url":"","image_ratio":"rounded","image_height":30,"highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["testimonial_48NWLm","testimonial_4qmgQm","testimonial_krhg8P"],"name":"t:sections.testimonials.name","settings":{"heading":"","heading_size":"title-md","heading_alignment":"text-center md:items-center","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":0,"padding_bottom":0,"divider":false,"rounded":false}},"image_with_text_yJHbyt":{"type":"image-with-text","blocks":{"heading_zKDTNi":{"type":"heading","settings":{"heading":"<strong>Ton formateur</strong>","heading_size":"title-md","heading_tag":"h2","highlighted_text":"half_text","highlighted_scribble":"circle","highlighted_reveal":true}},"text_ydDD6A":{"type":"text","settings":{"text":"<p>Je suis Swander — musicien, beatmaker et ingénieur du son depuis plus d'une décennie.</p><p>En plus de 10 ans sur Ableton, j'ai compris une chose essentielle : la plupart des producteurs ne manquent pas de créativité, <strong>ils manquent de technique, et de vision globale.</strong></p><p>Ils empilent des effets sans comprendre <strong>leur impact rée</strong>l<strong>.</strong> Ils corrigent au mix des problèmes créés à la production. Et même quand ils mixent,<strong> ils ne savent pas vraiment ce qu'ils entendent.</strong></p><p>C'est exactement pour ça que j'ai créé <em>L'Ingénieur de Précision.</em></p><p>Ce programme regroupe <strong>Space Wizard – Diagnostiquer et équilibrer le mix</strong>, <strong>La Boîte – Adapter un son à n'importe quel contexte</strong> et <strong>Ableton Effects – Utiliser les effets d'Ableton Live</strong> pour te donner une vision complète : comprendre le son en profondeur, maîtriser chaque outil qui le transforme, et savoir exactement ce que tu entends quand tu mixes.</p><p>Avec <a href=\"/products/space-wizard-diagnostiquer-et-equilibrer-le-mix\" title=\"Space Wizard - Diagnostiquer et équilibrer le mix\"><strong>Space Wizard</strong></a>, tu apprends à diagnostiquer et équilibrer n'importe quel mix : espace spectral, dynamique, stéréo. Tu cesses de corriger à l'aveugle.</p><p>Avec <a href=\"/products/la-boite-sound-designer-pour-mieux-mixer\" title=\"La Boîte - Adapter un son à n'importe quel contexte\"><strong>La Boîte</strong></a>, tu construis une base solide pour adapter tes sound design et tes presets : stéréo, traitement, cohérence, vision globale.</p><p>Avec <a href=\"/products/ableton-effects\" title=\"Ableton Effects - Utiliser les effets d'Ableton Live\"><strong>Ableton Effects</strong></a>, tu explores chaque effet natif d'Ableton Live pour apprendre à les utiliser avec intention, méthode et contrôle.</p><p>Mon approche reste la même : <strong>comprendre avant d'appliquer.</strong> Pas d'astuces isolées. Pas de recettes magiques.</p><p>Une logique claire qui te permet de <strong>savoir exactement ce que tu fais</strong> quand tu touches un paramètre.</p><p>Si tu veux arrêter de faire les choses sans logique et commencer à travailler avec <strong>précision, équilibre et maîtrise, </strong><em>L'Ingénieur de Précision</em> est <strong>l'archétype que tu dois chercher à devenir.</strong></p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"underline","highlighted_scribble":"circle"}},"liquid_7czmNh":{"type":"liquid","settings":{"liquid":"{%- assign p = all_products['l-ingenieur'] -%}\n{%- if p -%}\n\n  {%- assign v = p.selected_or_first_available_variant -%}\n\n  {%- assign mo = nil -%}\n\n  {%- if v and v.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = v.metafields.custom.buy_button.value -%}\n  {%- elsif p.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = p.metafields.custom.buy_button.value -%}\n  {%- endif -%}\n\n  {%- if mo -%}\n    {%- render 'meta-buy-button', mo: mo, force_label: 'Commencer le programme' -%}\n  {%- else -%}\n    <!-- buy_button introuvable (ni sur la variante, ni sur le produit) -->\n  {%- endif -%}\n\n{%- else -%}\n  <!-- Produit introuvable -->\n{%- endif -%}"}}},"block_order":["heading_zKDTNi","text_ydDD6A","liquid_7czmNh"],"custom_css":["/* Stop le zoom \"artificiel\" du thème */.image-with-text img,.image-with-text__media img,.image-with-text .media img {transform: none !important;}"],"name":"t:sections.image-with-text.name","settings":{"image":"shopify://shop_images/website_assets_qui_suis_je_formation.gif","image_height":"adapt","image_width":"small","layout":"text_first","text_alignment":"left","content_position":"align-self-center","image_height_mobile":"auto","text_alignment_mobile":"left","color_text":"","color_background":"#1e1e1e","gradient_background":"","color_background_2":"","gradient_background_2":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":88,"padding_bottom":88,"divider":false,"full_width":false,"rounded":true,"enable_parallax":true,"parallax_direction":"vertical"}},"faq_BgGDJU":{"type":"faq","blocks":{"question_UU6aHG":{"type":"question","settings":{"title":"Est-ce que les outils natifs d'Ableton suffisent pour un mixage professionnel ?","text":"<p>Oui. Le programme montre que les effets natifs d'Ableton Live sont largement suffisants pour un mixage professionnel si tu maîtrises réellement la stéréo, la dynamique et l'EQ</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_bpBceL":{"type":"question","settings":{"title":"Est-ce que je vais vraiment comprendre comment utiliser un EQ ?","text":"<p>Oui. L'EQ est travaillé en profondeur : identification des fréquences problématiques, nettoyage sans dénaturer le son, création d'espace entre les instruments et utilisation musicale de l'égalisation dans un mixage moderne.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_xKmKiC":{"type":"question","settings":{"title":"Comment mieux contrôler la dynamique d'un morceau ?","text":"<p>Tu verras en détail comment fonctionne la compression, comment préserver les transitoires, comment éviter d'écraser ton mix et comment utiliser la dynamique pour donner plus d'énergie et de clarté à tes productions.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_dmedLy":{"type":"question","settings":{"title":"Comment mieux gérer la stéréo dans un mix ?","text":"<p>Le programme t'explique comment répartir les éléments dans le champ stéréo, garder des basses solides en mono, éviter les conflits de phase et créer une largeur maîtrisée sans perdre en impact.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_EmDwPn":{"type":"question","settings":{"title":"Est-ce qu'on voit en détail les effets d'Ableton Live ?","text":"<p>Oui. La formation Ableton Effects incluse dans le programme passe en revue chaque effet natif : EQ Eight, compresseurs, outils de gestion de la dynamique, effets de stéréo, saturation et spatialisation. Tu apprends comment ils fonctionnent et surtout comment les utiliser dans un contexte réel de mixage.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_NpgdLV":{"type":"question","settings":{"title":"Est-ce adapté si je débute en mixage ?","text":"<p>Oui. Même si tu débutes, tu verras les bases essentielles du mixage audio : équilibre des fréquences avec l'EQ, contrôle de la dynamique avec la compression, gestion de la largeur stéréo et construction d'un mix clair et équilibré.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_UnikCx":{"type":"question","settings":{"title":"Est-ce que ce programme va m'aider à améliorer mon mixage ?","text":"<p>Oui. L'Ingénieur de Précision est conçu pour améliorer ton mixage à la source. Plutôt que d'ajouter des traitements au hasard, tu apprends à comprendre ce qui pose problème dans un son, comment le corriger avec un EQ, comment gérer la dynamique et comment organiser l'espace stéréo de manière cohérente.</p>","highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["question_UU6aHG","question_bpBceL","question_xKmKiC","question_dmedLy","question_EmDwPn","question_NpgdLV","question_UnikCx"],"custom_css":[],"name":"t:sections.faq.name","settings":{"style":"with-background","heading":"Questions fréquentes","heading_size":"title-md","heading_alignment":"text-left md:items-end md:flex-row","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","color_overlay":"#ffffff","overlay_opacity":4,"padding_top":0,"padding_bottom":0,"divider":false,"narrow":false,"rounded":false}},"image_with_text_overlay_dnpBHr":{"type":"image-with-text-overlay","blocks":{"heading_pjbK3T":{"type":"heading","settings":{"heading":"<strong>Et si ton vrai problème, c'était juste </strong><em><strong>ton manque de précision technique ?</strong></em>","heading_size":"title-sm","heading_tag":"p","highlighted_text":"underline","highlighted_scribble":"circle","highlighted_reveal":false}},"text_7W3cwK":{"type":"text","settings":{"text":"<p>Tu peux continuer à empiler des presets, corriger au hasard avec l’EQ, et exporter des morceaux “presque bons”.</p><p>Ou tu peux comprendre ton espace sonore, adapter tes sons intelligemment, et produire avec une vraie maîtrise technique.</p><p><strong>Équilibre ton spectre. Maîtrise ton espace. Deviens précis.</strong></p><p>Entre dans la peau de <strong>L'Ingénieur.</strong></p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"scribble","highlighted_scribble":"basic-underline"}},"liquid_wExkQQ":{"type":"liquid","settings":{"liquid":"{%- assign v = product.selected_or_first_available_variant -%}\n\n<p class=\"heading\" style=\"display:flex; gap:12px; align-items:baseline; font-size:clamp(24px, 5vw, 40px);\">\n  {%- if v.compare_at_price > v.price -%}\n    <s style=\"color:#B87533; opacity:0.9;\">\n      {{ v.compare_at_price | money }}\n    </s>\n  {%- endif -%}\n  <span>\n    {{ v.price | money }}\n  </span>\n</p>"}},"liquid_7fmcba":{"type":"liquid","settings":{"liquid":"{%- assign v = product.selected_or_first_available_variant -%}\n\n{%- if v.compare_at_price and v.compare_at_price > v.price -%}\n  {%- assign savings_cents = v.compare_at_price | minus: v.price -%}\n  <p class=\"sw-savings\">\n    {{ savings_cents | money_with_currency | replace: 'EUR', '' | strip }} euros d'économies\n  </p>\n{%- endif -%}"}},"liquid_pP9EHX":{"type":"liquid","settings":{"liquid":"{%- assign p = all_products['l-ingenieur'] -%}\n{%- if p -%}\n\n  {%- assign v = p.selected_or_first_available_variant -%}\n\n  {%- assign mo = nil -%}\n\n  {%- if v and v.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = v.metafields.custom.buy_button.value -%}\n  {%- elsif p.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = p.metafields.custom.buy_button.value -%}\n  {%- endif -%}\n\n  {%- if mo -%}\n    {%- render 'meta-buy-button', mo: mo, force_label: 'Commencer le programme' -%}\n  {%- else -%}\n    <!-- buy_button introuvable (ni sur la variante, ni sur le produit) -->\n  {%- endif -%}\n\n{%- else -%}\n  <!-- Produit introuvable -->\n{%- endif -%}"}}},"block_order":["heading_pjbK3T","text_7W3cwK","liquid_wExkQQ","liquid_7fmcba","liquid_pP9EHX"],"name":"t:sections.image-with-text-overlay.name","settings":{"transparent_header":false,"image":"shopify://shop_images/background_formation.png","image_height":"100vh","content_width":"small","content_position":"md:items-center md:justify-start","text_alignment":"left","image_height_mobile":"auto","content_position_mobile":"items-end justify-start","text_alignment_mobile":"left","color_text":"#ffffff","color_background":"","gradient_background":"","color_highlight":"#b87533","gradient_highlight":"","color_button_text":"#171717","color_button_background":"#b87533","color_button_gradient":"","color_overlay":"#171717","overlay_opacity":60,"padding_top":0,"padding_bottom":0,"divider":false,"full_width":true,"rounded":false,"enable_parallax":true,"parallax_direction":"vertical"}},"product-recommendations":{"type":"product-recommendations","settings":{"product_limit":3,"columns":3,"carousel_on_desktop"