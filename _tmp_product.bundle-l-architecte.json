g","settings":{"heading":"<strong>Ce que disent </strong><em><strong> mes clients</strong></em>","heading_size":"title-md","heading_tag":"h2","highlighted_text":"scribble","highlighted_scribble":"basic-underline","highlighted_reveal":false}},"text_DWBj6d":{"type":"text","settings":{"text":"<p>Des résultats concrets pour des producteurs comme toi</p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["heading_U6BcM6","text_DWBj6d"],"name":"t:sections.rich-text.name","settings":{"text_alignment":"center","text_alignment_mobile":"center","heading":"","heading_size":"title-md","heading_alignment":"text-left md:items-end md:flex-row","heading_width":"small","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":88,"padding_bottom":88,"divider":false,"narrow":true,"rounded":false}},"testimonials_8ERKtF":{"type":"testimonials","blocks":{"testimonial_48NWLm":{"type":"testimonial","settings":{"icon":"quote","text":"<p>Add customer reviews and testimonials to showcase your store’s happy customers.</p>","author":"Author's name","author_info":"","author_url":"","image_ratio":"rounded","image_height":30,"highlighted_text":"none","highlighted_scribble":"circle"}},"testimonial_4qmgQm":{"type":"testimonial","settings":{"icon":"quote","text":"<p>Add customer reviews and testimonials to showcase your store’s happy customers.</p>","author":"Author's name","author_info":"","author_url":"","image_ratio":"rounded","image_height":30,"highlighted_text":"none","highlighted_scribble":"circle"}},"testimonial_krhg8P":{"type":"testimonial","settings":{"icon":"quote","text":"<p>Add customer reviews and testimonials to showcase your store’s happy customers.</p>","author":"Author's name","author_info":"","author_url":"","image_ratio":"rounded","image_height":30,"highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["testimonial_48NWLm","testimonial_4qmgQm","testimonial_krhg8P"],"name":"t:sections.testimonials.name","settings":{"heading":"","heading_size":"title-md","heading_alignment":"text-center md:items-center","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":0,"padding_bottom":88,"divider":false,"rounded":false}},"image_with_text_yJHbyt":{"type":"image-with-text","blocks":{"heading_zKDTNi":{"type":"heading","settings":{"heading":"<strong>Ton formateur</strong>","heading_size":"title-md","heading_tag":"h2","highlighted_text":"half_text","highlighted_scribble":"circle","highlighted_reveal":true}},"text_ydDD6A":{"type":"text","settings":{"text":"<p>Je suis <strong>Swander — musicien, producteur et ingénieur du son depuis plus d’une décennie</strong>. </p><p>J’ai commencé comme beaucoup : en testant, en accumulant des idées, en espérant que “ça sonne”. Puis j’ai voulu comprendre pourquoi certains morceaux tiennent debout… et pourquoi d’autres s’effondrent, sont mal construits, ou ne sonnent pas.</p><p>Avec le temps, j’ai réalisé que produire ne consiste pas à empiler des éléments. Ça consiste à <strong>construire</strong>. </p><p>Un Architecte ne choisit pas ses matériaux au hasard. Il comprend les <strong>fondations</strong>, il anticipe les <strong>tensions</strong>, il pense les <strong>espaces</strong> avant même qu’ils n’existent. Il sait comment chaque élément interagit avec l’ensemble.</p><p>C’est cette posture que je transmets dans <strong>L’Architecte Sonore</strong>. Comprendre les <strong>fondations harmoniques</strong> d’un morceau, maîtriser sa <strong>structure</strong>, organiser l’<strong>espace</strong>, sculpter la <strong>matière sonore</strong> en profondeur. Ne plus dépendre de l’instinct fragile ou du hasard, mais produire avec une <strong>vision claire, cohérente et maîtrisée</strong>.</p><p>Un producteur assemble sans vision d'ensemble.<br/><br/>Un <strong>Architecte comprend le bâtiment dans sa totalité</strong>.</p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"underline","highlighted_scribble":"circle"}},"liquid_7czmNh":{"type":"liquid","settings":{"liquid":"{%- assign p = all_products['larchitecte'] -%}\n{%- if p -%}\n\n  {%- assign v = p.selected_or_first_available_variant -%}\n\n  {%- assign mo = nil -%}\n\n  {%- if v and v.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = v.metafields.custom.buy_button.value -%}\n  {%- elsif p.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = p.metafields.custom.buy_button.value -%}\n  {%- endif -%}\n\n  {%- if mo -%}\n    {%- render 'meta-buy-button', mo: mo, force_label: 'Commencer le programme' -%}\n  {%- else -%}\n    <!-- buy_button introuvable (ni sur la variante, ni sur le produit) -->\n  {%- endif -%}\n\n{%- else -%}\n  <!-- Produit introuvable -->\n{%- endif -%}"}}},"block_order":["heading_zKDTNi","text_ydDD6A","liquid_7czmNh"],"custom_css":["/* Stop le zoom \"artificiel\" du thème */.image-with-text img,.image-with-text__media img,.image-with-text .media img {transform: none !important;}"],"name":"t:sections.image-with-text.name","settings":{"image":"shopify://shop_images/website_assets_qui_suis_je_formation.gif","image_height":"adapt","image_width":"small","layout":"text_first","text_alignment":"left","content_position":"align-self-center","image_height_mobile":"auto","text_alignment_mobile":"left","color_text":"","color_background":"#1e1e1e","gradient_background":"","color_background_2":"","gradient_background_2":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":0,"padding_bottom":88,"divider":false,"full_width":false,"rounded":true,"enable_parallax":true,"parallax_direction":"vertical"}},"faq_BgGDJU":{"type":"faq","blocks":{"question_ywMTQU":{"type":"question","settings":{"title":"Combien d'heures de contenu sont incluses ?","text":"<p>Le programme contient plus de 30 heures de formation vidéo réparties sur 125 leçons, couvrant l'harmonie, la composition, la structure et le sound design de manière approfondie.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_t3gk4x":{"type":"question","settings":{"title":"Est-ce adapté aux producteurs intermédiaires ?","text":"<p>Oui, particulièrement. Si tu connais déjà ton DAW mais que tu manques de cohérence ou de vision globale, ce programme est pensé pour franchir un cap.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_X8Gc7y":{"type":"question","settings":{"title":"Quelle est la différence entre ce programme et une formation classique en production ?","text":"<p>Une formation classique t'enseigne un domaine précis. L'Architecte Sonore relie harmonie, composition, structure et sound design dans une vision globale. C'est une approche architecturale de la production musicale.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_ELpW7A":{"type":"question","settings":{"title":"Est-ce que je vais apprendre le sound design en profondeur ?","text":"<p>Oui. Avec Sound Design Master et La Boîte, tu apprends à comprendre la matière sonore, la synthèse, l'espace stéréo et l'adaptation d'un son à son environnement musical.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_zPRnrE":{"type":"question","settings":{"title":"Est-ce compatible avec tous les DAW ?","text":"<p>Oui. Même si certaines démonstrations sont faites sur Ableton Live, les principes de production, de composition et de sound design sont universels et applicables sur tous les DAW.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_C8UGBK":{"type":"question","settings":{"title":"Est-ce que ce programme améliore aussi le mixage ?","text":"<p>Indirectement, oui — et fortement. En travaillant la structure, l'espace et le sound design dès la production, tu simplifies énormément le mixage. Tu produis des sons mieux équilibrés et plus adaptés à leur contexte.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_pX4Jfa":{"type":"question","settings":{"title":"Est-ce adapté si je bloque en composition ou en harmonie ?","text":"<p>Oui. La partie théorie musicale te permet de comprendre les accords, les gammes et les progressions harmoniques sans solfège. Tu apprendras à composer avec plus de contrôle, d'émotion et de cohérence.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_dVB3Tt":{"type":"question","settings":{"title":"Est-ce que ce programme aide vraiment à progresser en production musicale ?","text":"<p>Oui. L'Architecte Sonore est conçu pour structurer l'ensemble de ton processus de production musicale : harmonie, composition, structure, sound design et cohérence globale. L'objectif est de transformer ta manière de produire, pas seulement d'ajouter quelques techniques.</p>","highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["question_ywMTQU","question_t3gk4x","question_X8Gc7y","question_ELpW7A","question_zPRnrE","question_C8UGBK","question_pX4Jfa","question_dVB3Tt"],"custom_css":[],"name":"t:sections.faq.name","settings":{"style":"with-background","heading":"Questions fréquentes","heading_size":"title-md","heading_alignment":"text-left md:items-end md:flex-row","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","color_overlay":"#ffffff","overlay_opacity":4,"padding_top":0,"padding_bottom":0,"divider":false,"narrow":false,"rounded":false}},"image_with_text_overlay_dnpBHr":{"type":"image-with-text-overlay","blocks":{"heading_pjbK3T":{"type":"heading","settings":{"heading":"<strong>Prêt à construire de véritables merveilles sonores ?</strong>","heading_size":"title-sm","heading_tag":"p","highlighted_text":"underline","highlighted_scribble":"circle","highlighted_reveal":false}},"text_7W3cwK":{"type":"text","settings":{"text":"<p>L’Architecte Sonore est un <strong>changement de posture</strong>. Celui qui passe de l’exécutant au concepteur. De l’intuition floue à la maîtrise consciente.</p><p>Ici, tu n’achètes pas quelques techniques supplémentaires. Tu investis dans une <strong>garantie absolue de ne plus jamais douter de tes fondations</strong>. Harmonie, structure, espace, son : tout est relié, compris, intégré.</p><p>À partir de là, tu ne produis plus en espérant que ça fonctionne. <strong>Tu sais pourquoi ça fonctionne. T</strong>u construis avec autorité.</p><p>Entre dans la peau de <strong>l'Architecte</strong>.</p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"scribble","highlighted_scribble":"basic-underline"}},"liquid_wExkQQ":{"type":"liquid","settings":{"liquid":"{%- assign v = product.selected_or_first_available_variant -%}\n\n<p class=\"heading\" style=\"display:flex; gap:12px; align-items:baseline; font-size:clamp(24px, 5vw, 40px);\">\n  {%- if v.compare_at_price > v.price -%}\n    <s style=\"color:#B87533; opacity:0.9;\">\n      {{ v.compare_at_price | money }}\n    </s>\n  {%- endif -%}\n  <span>\n    {{ v.price | money }}\n  </span>\n</p>"}},"liquid_7fmcba":{"type":"liquid","settings":{"liquid":"{%- assign v = product.selected_or_first_available_variant -%}\n\n{%- if v.compare_at_price and v.compare_at_price > v.price -%}\n  {%- assign savings_cents = v.compare_at_price | minus: v.price -%}\n  <p class=\"sw-savings\">\n    {{ savings_cents | money_with_currency | replace: 'EUR', '' | strip }} euros d'économies\n  </p>\n{%- endif -%}"}},"text_CccjWL":{"type":"text","settings":{"text":"<p><strong>Paiement en plusieurs fois disponible ⸱  Accès </strong><em><strong>  à vie</strong></em></p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}},"liquid_pP9EHX":{"type":"liquid","settings":{"liquid":"{%- assign p = all_products['larchitecte'] -%}\n{%- if p -%}\n\n  {%- assign v = p.selected_or_first_available_variant -%}\n\n  {%- assign mo = nil -%}\n\n  {%- if v and v.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = v.metafields.custom.buy_button.value -%}\n  {%- elsif p.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = p.metafields.custom.buy_button.value -%}\n  {%- endif -%}\n\n  {%- if mo -%}\n    {%- render 'meta-buy-button', mo: mo, force_label: 'Commencer le programme' -%}\n  {%- else -%}\n    <!-- buy_button introuvable (ni sur la variante, ni sur le produit) -->\n  {%- endif -%}\n\n{%- else -%}\n  <!-- Produit introuvable -->\n{%- endif -%}"}}},"block_order":["heading_pjbK3T","text_7W3cwK","liquid_wExkQQ","liquid_7fmcba","text_CccjWL","liquid_pP