!important;margin-bottom:40px!important;position:relative} .product__info::before{content:\"\";position:absolute;top:0;left:30px;right:30px;height:1.5px; background:linear-gradient(90deg,transparent,#B87533 50%,transparent);opacity:.6} .product__title,.product__title *{font-family:'Outfit','Segoe UI',system-ui,sans-serif!important; font-weight:800!important;letter-spacing:-.02em!important;color:#fff!important} .spp2__widget{margin:6px 0 14px 0!important} .spp2__widget-options{display:flex!important;gap:6px!important;background:#0e0e0e!important; border:1px solid rgba(255,255,255,.08)!important;border-radius:999px!important; padding:4px!important;list-style:none!important;margin:6px 0 12px 0!important} .spp2__widget-option{flex:1;margin:0!important;list-style:none!important; position:relative;border:none!important;padding:0!important;background:transparent!important} .spp2__widget-option input[type=radio]{position:absolute;inset:0;opacity:0;pointer-events:auto; width:100%;height:100%;margin:0;cursor:pointer;z-index:2} .spp2__widget-option .spp2__radio{display:none!important} .spp2__widget-option .spp2__payment-option-content{display:block!important; padding:10px 14px!important;border-radius:999px!important; text-align:center!important;cursor:pointer!important; transition:background .25s ease!important; background:transparent!important;border:none!important;position:relative;z-index:1} .spp2__widget-option .spp2__payment-option-label{display:block!important; font-family:'Outfit',sans-serif!important;font-weight:700!important;font-size:12.5px!important; color:#8c8c8c!important;letter-spacing:.02em!important;cursor:pointer!important; margin:0!important;padding:0!important;transition:color .25s ease!important} .spp2__widget-option input[type=radio]:checked ~ .spp2__payment-option-content{ background:#B87533!important; box-shadow:0 6px 14px -6px rgba(184,117,51,.7)!important} .spp2__widget-option input[type=radio]:checked ~ .spp2__payment-option-content .spp2__payment-option-label{ color:#181818!important} .spp2__widget-info{margin-top:10px!important;padding:12px 14px!important; background:rgba(184,117,51,.06)!important;border:1px solid rgba(184,117,51,.18)!important; border-radius:10px!important;font-size:13px!important;color:#dcdcdc!important} .spp2__widget-info b{color:#fff!important} .spp2__widget-note{margin-top:6px!important;font-size:12px!important;color:#a0a0a0!important} .product__info p strong{color:#fff!important} [id*=\"__main-product\"]{position:relative;z-index:2} \n</style>\n<div class=\"swc-root\">\n<!-- STATS BAND --><div class=\"swc-stats\"><div class=\"swc-wrap\"><div class=\"swc-stat\"><b>33</b><span>leçons</span></div><div class=\"swc-stat\"><b>8h08</b><span>de formation</span></div><div class=\"swc-stat\"><b>4</b><span>modules</span></div><div class=\"swc-stat\"><b>Serum 2</b><span>v2 complète</span></div><div class=\"swc-stat\"><b><em>5,0</em>★</b><span>note des élèves</span></div><div class=\"swc-stat\"><b>À vie</b><span>ton accès</span></div></div></div><!-- PAIN --><section class=\"swc-section\"><div class=\"swc-wrap swc-center\"><span class=\"swc-kicker\">Le vrai blocage</span><h2 class=\"heading leading-none title-md tracking-heading\"><strong>Tu as ouvert Serum. Mais tu n'as <em>jamais vraiment plongé dedans</em>.</strong></h2><div class=\"swc-pain-grid\" style=\"text-align:left\"><div class=\"swc-pcard\"><div class=\"swc-picon\"><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\"/></svg></div><h3>Tu charges des presets sans comprendre</h3><p>Tu sens que l'outil est puissant, mais tu restes <b style=\"color:#fff\">à la surface de ses possibilités</b>. Impossible de modifier un preset sans tout casser.</p></div><div class=\"swc-pcard\"><div class=\"swc-picon\"><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M9 12l2 2 4-4M12 7v1M12 16v1\"/></svg></div><h3>L'interface te fait peur</h3><p>Cinq oscillateurs, une matrice de modulation, des LFO, des effets… L'interface ressemble à un cockpit. Tu ne sais pas par où commencer.</p></div><div class=\"swc-pcard\"><div class=\"swc-picon\"><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M3 18V6M7 18V11M11 18V8M15 18V4M19 18V13\"/></svg></div><h3>Tu n'as pas développé ton identité sonore</h3><p>Et c'est précisément Serum 2 qui peut t'y aider — sa version 2.0 l'a rendu totalement incontournable pour <b style=\"color:#fff\">créer la tienne</b>.</p></div></div></div></section><!-- POUR QUI --><section class=\"swc-section swc-shift\"><div class=\"swc-wrap\"><div class=\"swc-center\"><span class=\"swc-kicker swc-c\">Pour qui</span><h2 class=\"heading leading-none title-md tracking-heading\"><strong>Est-ce que c'est pour toi ?</strong></h2></div><div class=\"swc-ba\"><div class=\"swc-bacard swc-after\"><div class=\"swc-balabel\"><span class=\"swc-dot\"></span>Pour toi si</div><ul class=\"swc-balist\"><li><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>Tu t'intéresses de près ou de loin au <b>sound design</b></li><li><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>Tu as déjà ouvert Serum, chargé quelques presets, <b>sans vraiment savoir t'en servir</b></li><li><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>Tu veux développer <b>ta propre identité sonore</b>, peu importe ton style</li><li><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>Tu veux t'amuser plus en produisant en comprenant <b>comment les sons sont faits</b></li></ul></div><div class=\"swc-bacard swc-before\"><div class=\"swc-balabel\"><span class=\"swc-dot\"></span>Pas pour toi si</div><ul class=\"swc-balist\"><li><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\"><path d=\"M18 6 6 18M6 6l12 12\"/></svg>Tu veux uniquement empiler des presets sans chercher à comprendre</li><li><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\"><path d=\"M18 6 6 18M6 6l12 12\"/></svg>Tu ne veux pas apprendre les bases du fonctionnement d'un synthétiseur</li><li><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\"><path d=\"M18 6 6 18M6 6l12 12\"/></svg>Tu cherches une solution rapide sans logique ni progression</li><li><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\"><path d=\"M18 6 6 18M6 6l12 12\"/></svg>Tu ne souhaites pas investir du temps pour développer ton univers sonore</li></ul></div></div></div></section><!-- BRIDGE --><section class=\"swc-section swc-bridge\"><div class=\"swc-wrap\"><span class=\"swc-kicker swc-c\">Le concept</span><p class=\"swc-big\">Serum est <em>LA référence en sound design</em>. Sa v2.0 l'a rendu <em>incontournable</em>.</p><p>C'est un mastodonte, un monument. Et si certains doutaient encore de sa capacité à se renouveler, sa <b style=\"color:#fff\">version 2.0</b> l'a rendu totalement incontournable pour quiconque veut développer <b style=\"color:#fff\">sa propre identité sonore</b>. Cette formation te montre comment exploiter Serum 2 <b style=\"color:#fff\">dans toute sa profondeur</b>, du premier oscillateur au sound design hybride.</p></div></section><!-- 3 PILIERS --><section class=\"swc-section swc-spaces\"><div class=\"swc-wrap swc-center\"><span class=\"swc-kicker\">3 niveaux progressifs</span><h2 class=\"heading leading-none title-md tracking-heading\"><strong>Du débutant au master, sans saut dans le vide.</strong></h2><div class=\"swc-sp-grid\"><div class=\"swc-sp\"><div class=\"swc-spi\"><svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M12 7v5l3 2\"/></svg></div><h3><em>Niveau 1</em>Débutant — les modules de Serum</h3><p>Tour des modules, oscillateurs, filtres, enveloppes, LFO, effets. Tu apprends à créer tes premiers sons analogiques et tes drums.</p></div><div class=\"swc-sp\"><div class=\"swc-spi\"><svg viewBox=\"0 0 24 24\"><path d=\"M9 3v6h6V3M3 21V11h6M21 21V11h-6M9 9h6M3 21h18\"/></svg></div><h3><em>Niveau 2</em>Avancé — espace et modulation</h3><p>Stéréo, modificateurs d'ondes, synthèses à modulation, FM, LFO avancés, sound design aléatoire. Tu sors du sound design « plat ».</p></div><div class=\"swc-sp\"><div class=\"swc-spi\"><svg viewBox=\"0 0 24 24\"><path d=\"M3 12h3l2-7 4 14 2-7 2 4h5\"/></svg></div><h3><em>Niveau 3</em>Master — Serum 2 à fond</h3><p>Wavetables custom, granulaire, spectral, distorsion de phase, sampling avancé, sound design hybride. <b>Tu maîtrises tous les Serum 2.</b></p></div></div></div></section><!-- LEARN --><section class=\"swc-section swc-learn\"><div class=\"swc-wrap swc-center\"><span class=\"swc-kicker swc-c\">Le résultat</span><h2 class=\"heading leading-none title-md tracking-heading\"><strong>Ce que tu vas apprendre</strong></h2><ul class=\"swc-learn-grid\" style=\"text-align:left\"><li><span class=\"swc-lc\"><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span><span>Créer tes sons de A à Z avec le synthétiseur <b>le plus puissant du marché</b></span></li><li><span class=\"swc-lc\"><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span><span>Comprendre <b>les possibilités infinies de Serum</b> en matière de sound design</span></li><li><span class=\"swc-lc\"><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span><span>Créer littéralement <b>n'importe quel type de son</b> — drums, synthés, instruments acoustiques</span></li><li><span class=\"swc-lc\"><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span><span>Intégrer Serum dans un <b>parcours logique et structuré</b></span></li><li><span class=\"swc-lc\"><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span><span>Créer des sons simples mais <b>parfaitement utilisables</b> dès les premiers modules</span></li><li><span class=\"swc-lc\"><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span><span>Maîtriser la <b>matrice et la vue mix</b> niveau master</span></li><li><span class=\"swc-lc\"><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span><span>Explorer la <b>synthèse granulaire et spectrale</b> de Serum 2</span></li><li><span class=\"swc-lc\"><svg viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span><span>Forger <b>ton identité sonore</b> avec le synthé de référence</span></li></ul></div></section><!-- PROGRAMME --><section class=\"swc-section\"><div class=\"swc-wrap swc-center\"><span class=\"swc-kicker\">Le contenu</span><h2 class=\"heading leading-none title-md tracking-heading\"><strong>Programme de la formation</strong></h2><p style=\"margin-top:14px;color:var(--body);font-size:15px\">33 leçons · 8h08 de vidéo · 4 modules — Serum 2 de A à Z</p><div class=\"swc-mods\"><details class=\"swc-mod\" open><summary><span class=\"swc-mnum\">01</span><span class=\"swc-mttl\">Introduction</span><span class=\"swc-pm\">+</span></summary><div class=\"swc-mbody\"><p class=\"swc-mobj\"><b>Objectif :</b> poser les fondations conceptuelles du son avant de plonger dans Serum.</p><ul><li><b>1.A</b>Introduction</li><li><b>1.B</b>Les 3 piliers du son</li><li><b>1.C</b>La phase</li></ul></div></details><details class=\"swc-mod\"><summary><span class=\"swc-mnum\">02</span><span class=\"swc-mttl\">Niveau débutant</span><span class=\"swc-pm\">+</span></summary><div class=\"swc-mbody\"><p class=\"swc-mobj\"><b>Objectif :</b> tour complet de Serum module par module. Sortir avec des sons analogiques et des drums utilisables.</p><ul><li><b>2.A</b>Tour des modules</li><li><b>2.B</b>Les oscillateurs</li><li><b>2.C</b>Les filtres</li><li><b>2.D</b>Enveloppes et LFO</li><li><b>2.E</b>Les effets</li><li><b>2.F</b>Vue matrice et macros</li><li><b>2.G</b>Bonus — sound design analogique</li><li><b>2.H</b>Bonus — sound design de drums</li></ul></div></details><details class=\"swc-mod\"><summary><span class=\"swc-mnum\">03</span><span class=\"swc-mttl\">Niveau avancé</span><span class=\"swc-pm\">+</span></summary><div class=\"swc-mbody\"><p class=\"swc-mobj\"><b>Objectif :</b> stéréo, modulation, FM, LFO avancés, aléatoire. Sortir du sound design « plat ».</p><ul><li><b>3.A</b>Introduction à la stéréo</li><li><b>3.B</b>Modificateurs d'ondes</li><li><b>3.C</b>Synthèses à modulation</li><li><b>3.D</b>Sound design à partir de FM</li><li><b>3.E</b>LFO avancés</li><li><b>3.F</b>Sound design aléatoire</li><li><b>3.G</b>Module d'effets — niveau intermédiaire</li><li><b>3.H</b>Sound design de sons stéréo</li></ul></div></details><details class=\"swc-mod\"><summary><span class=\"swc-mnum\">04</span><span class=\"swc-mttl\">Niveau master — Serum 2 à fond</span><span class=\"swc-pm\">+</span></summary><div class=\"swc-mbody\"><p class=\"swc-mobj\"><b>Objectif :</b> exploiter toutes les nouveautés de Serum 2. Wavetables custom, granulaire, spectral, hybride.</p><ul><li><b>4.A</b>Vue mix et matrice — niveau master</li><li><b>4.B</b>Mode clip et mode arp</li><li><b>4.C</b>Création et édition de wavetables</li><li><b>4.D</b>Tous les filtres de Serum 2</li><li><b>4.E</b>Voicing — niveau master</li><li><b>4.F</b>Sampling — niveau master</li><li><b>4.G</b>Distorsion et splits</li><li><b>4.H</b>Synthèse à distorsion de phase</li><li><b>4.I</b>Synthèse granulaire</li><li><b>4.J</b>Sound design granulaire</li><li><b>4.K</b>Synthèse spectrale</li><li><b>4.L</b>Sound design spectral</li><li><b>4.M</b>Sound design hybride</li></ul></div></details></div></div></section>\n</div>\n",
