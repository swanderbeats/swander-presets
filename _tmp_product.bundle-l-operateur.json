e: 18px;\n  font-weight: bold;\n\">\n  CE QUE TU VAS APPRENDRE : \n</h2>"},"blocks":{}},"spacer_Mrxp8q":{"type":"spacer","name":"t:blocks.spacer.name","disabled":true,"settings":{"size":"percent","percent_size":100,"pixel_size":120,"custom_mobile_size":false,"size_mobile":"percent","percent_size_mobile":100,"pixel_size_mobile":120},"blocks":{}},"text_FDwKdW":{"type":"text","name":"t:blocks.text.name","settings":{"text":"<p>• <strong>Maîtriser Ableton Live de A à Z</strong> (interface, routing, méthodes, raccourcis utiles)<br/>• <strong>Arrêter de sous-utiliser</strong> les instruments et effets natifs<br/>• <strong>Comprendre ce que tu fais</strong> quand tu touches chaque paramètre<br/>• <strong>Produire plus vite</strong> avec un workflow propre et reproductible<br/>• <strong>Passer d’une loop à un projet cohérent et terminé</strong><br/>• <strong>Structurer l’énergie</strong> d’un morceau (tension, relâchement, variations, transitions)<br/>• <strong>Éviter les erreurs classiques</strong> (surcharge, procrastination, manque de direction)<br/>• Construire un <strong>mix cohérent</strong> dès la création (sons qui s’imbriquent, espace, hiérarchie)<br/>• Développer une <strong>méthode universelle</strong> applicable à tous les styles<br/>• Repartir avec des <strong>concepts concrets</strong> qui te guident sans t’enfermer</p>","text_font":"body","text_size":"text-base","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"width":"fit-content","custom_width":100,"alignment":"left","width_mobile":"fit-content","custom_width_mobile":100,"effects":"none","highlighted_text":"text","highlighted_scribble":"circle"},"blocks":{}},"spacer_FYBerF":{"type":"spacer","name":"t:blocks.spacer.name","settings":{"size":"percent","percent_size":100,"pixel_size":120,"custom_mobile_size":false,"size_mobile":"percent","percent_size_mobile":100,"pixel_size_mobile":120},"blocks":{}},"custom_liquid_fdxk9q":{"type":"custom-liquid","