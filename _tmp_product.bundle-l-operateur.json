ultats concrets pour des producteurs comme toi</p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["heading_U6BcM6","text_DWBj6d"],"name":"t:sections.rich-text.name","settings":{"text_alignment":"center","text_alignment_mobile":"center","heading":"","heading_size":"title-md","heading_alignment":"text-left md:items-end md:flex-row","heading_width":"small","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":88,"padding_bottom":88,"divider":false,"narrow":true,"rounded":false}},"testimonials_8ERKtF":{"type":"testimonials","blocks":{"testimonial_48NWLm":{"type":"testimonial","settings":{"icon":"quote","text":"<p>Add customer reviews and testimonials to showcase your store’s happy customers.</p>","author":"Author's name","author_info":"","author_url":"","image_ratio":"rounded","image_height":30,"highlighted_text":"none","highlighted_scribble":"circle"}},"testimonial_4qmgQm":{"type":"testimonial","settings":{"icon":"quote","text":"<p>Add customer reviews and testimonials to showcase your store’s happy customers.</p>","author":"Author's name","author_info":"","author_url":"","image_ratio":"rounded","image_height":30,"highlighted_text":"none","highlighted_scribble":"circle"}},"testimonial_krhg8P":{"type":"testimonial","settings":{"icon":"quote","text":"<p>Add customer reviews and testimonials to showcase your store’s happy customers.</p>","author":"Author's name","author_info":"","author_url":"","image_ratio":"rounded","image_height":30,"highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["testimonial_48NWLm","testimonial_4qmgQm","testimonial_krhg8P"],"name":"t:sections.testimonials.name","settings":{"heading":"","heading_size":"title-md","heading_alignment":"text-center md:items-center","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":0,"padding_bottom":0,"divider":false,"rounded":false}},"image_with_text_yJHbyt":{"type":"image-with-text","blocks":{"heading_zKDTNi":{"type":"heading","settings":{"heading":"<strong>Ton formateur</strong>","heading_size":"title-md","heading_tag":"h2","highlighted_text":"half_text","highlighted_scribble":"circle","highlighted_reveal":true}},"text_ydDD6A":{"type":"text","settings":{"text":"<p>Je suis Swander — musicien, beatmaker et ingénieur du son depuis plus de dix ans.</p><p>Depuis un moment, je me suis donné pour mission d’aider les producteurs à progresser pour pouvoir s’exprimer librement.</p><p>Beaucoup ont peur de toucher aux boutons, de peur de tout faire exploser. D’autres trouvent ça chiant… et ne goûtent jamais à la vraie récompense : celle de créer un son à ton image, puis de transformer une idée en morceau solide.</p><p>Souvent, tu penses que ton problème, c’est “le mix”, “la sound selection”, “l’arrangement”… mais en réalité, beaucoup de choses se règlent dès la création, en choisissant ou en créant les bons sons, qui s'imbriquent bien ensemble.</p><p>L’Opérateur, c’est exactement ça : reprendre le contrôle d'Ableton Live et de ses plug(ins, puis apprendre à produire avec une vraie vision.</p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"underline","highlighted_scribble":"circle"}},"liquid_7czmNh":{"type":"liquid","settings":{"liquid":"{%- assign p = all_products['loperateur'] -%}\n{%- if p -%}\n\n  {%- assign v = p.selected_or_first_available_variant -%}\n\n  {%- assign mo = nil -%}\n\n  {%- if v and v.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = v.metafields.custom.buy_button.value -%}\n  {%- elsif p.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = p.metafields.custom.buy_button.value -%}\n  {%- endif -%}\n\n  {%- if mo -%}\n    {%- render 'meta-buy-button', mo: mo, force_label: 'Commencer le programme' -%}\n  {%- else -%}\n    <!-- buy_button introuvable (ni sur la variante, ni sur le produit) -->\n  {%- endif -%}\n\n{%- else -%}\n  <!-- Produit introuvable -->\n{%- endif -%}"}}},"block_order":["heading_zKDTNi","text_ydDD6A","liquid_7czmNh"],"custom_css":["/* Stop le zoom \"artificiel\" du thème */.image-with-text img,.image-with-text__media img,.image-with-text .media img {transform: none !important;}"],"name":"t:sections.image-with-text.name","settings":{"image":"shopify://shop_images/website_assets_qui_suis_je_formation.gif","image_height":"adapt","image_width":"small","layout":"text_first","text_alignment":"left","content_position":"align-self-center","image_height_mobile":"auto","text_alignment_mobile":"left","color_text":"","color_background":"#1e1e1e","gradient_background":"","color_background_2":"","gradient_background_2":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":88,"padding_bottom":88,"divider":false,"full_width":false,"rounded":true,"enable_parallax":true,"parallax_direction":"vertical"}},"faq_BgGDJU":{"type":"faq","blocks":{"question_bGw4M8":{"type":"question","settings":{"title":"Puis-je suivre ce programme sans faire de sound design avancé ?","text":"<p>Oui. L'objectif n'est pas de te transformer en sound designer, mais de te rendre autonome sur l'outil et la production.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_dFdndB":{"type":"question","settings":{"title":"Quelle est la différence entre acheter séparément et prendre L'Opérateur ?","text":"<p>En achetant le bundle, tu as l'ensemble pour 397 € au lieu de 494 € (valeur catalogue).</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_KK6kJb":{"type":"question","settings":{"title":"Combien de leçons contient le bundle L'Opérateur ?","text":"<p>84 leçons au total.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_CxXyQe":{"type":"question","settings":{"title":"Combien d'heures de contenu vidéo contient L'Opérateur ?","text":"<p>22h19 de vidéo au total.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_xDccDV":{"type":"question","settings":{"title":"Les méthodes de Production Master fonctionnent-elles en rap, house, techno, pop...?c'est","text":"<p>Oui. Les concepts sont universels : hiérarchie, énergie, contraste, transitions, cohérence.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_hwM9YU":{"type":"question","settings":{"title":"Est-ce que ce programme aide vraiment à finir ses morceaux ?","text":"<p>Oui. Production Master est centré sur la structure, l'énergie, les variations et le passage de la loop au morceau.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_kp8MtF":{"type":"question","settings":{"title":"Est-ce une formation Ableton Live orientée instruments et effets natifs ?","text":"<p>Oui. Le programme est conçu pour exploiter les outils natifs (instruments + effets) plutôt que dépendre de plugins tiers.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_9AghEx":{"type":"question","settings":{"title":"L'Opérateur est-il adapté aux débutants sur Ableton Live ?","text":"<p>Oui. Ableton Master reprend les bases et t'amène progressivement vers un usage solide et autonome.</p>","highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["question_bGw4M8","question_dFdndB","question_KK6kJb","question_CxXyQe","question_xDccDV","question_hwM9YU","question_kp8MtF","question_9AghEx"],"custom_css":[],"name":"t:sections.faq.name","settings":{"style":"with-background","heading":"Questions fréquentes","heading_size":"title-md","heading_alignment":"text-left md:items-end md:flex-row","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","color_overlay":"#ffffff","overlay_opacity":4,"padding_top":0,"padding_bottom":0,"divider":false,"narrow":false,"rounded":false}},"image_with_text_overlay_dnpBHr":{"type":"image-with-text-overlay","blocks":{"heading_pjbK3T":{"type":"heading","settings":{"heading":"<strong>Et si ton vrai problème, c’était juste </strong><em><strong>ton environnement ?</strong></em>","heading_size":"title-sm","heading_tag":"p","highlighted_text":"underline","highlighted_scribble":"circle","highlighted_reveal":false}},"text_7W3cwK":{"type":"text","settings":{"text":"<p>Tu peux avoir du goût, des idées, des références… si ton workflow est flou, si tes sessions sont en bordel, et si tu ne maîtrises pas ton outil, tu vas continuer à perdre du temps et à douter à chaque étape.</p><p>Avec L’Opérateur, tu récupères le contrôle : <strong>Ableton devient un terrain connu</strong>, et ta production suit une méthode qui t’emmène jusqu’au bout. Résultat : tu vas plus vite, tu fais des choix plus propres, et tu termines des morceaux qui tiennent debout.</p><p>Si tu veux arrêter de “faire des loops” et commencer à sortir des titres finis, c’est exactement le programme à prendre.</p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"scribble","highlighted_scribble":"basic-underline"}},"liquid_wExkQQ":{"type":"liquid","settings":{"liquid":"{%- assign v = product.selected_or_first_available_variant -%}\n\n<p class=\"heading\" style=\"display:flex; gap:12px; align-items:baseline; font-size:clamp(24px, 5vw, 40px);\">\n  {%- if v.compare_at_price > v.price -%}\n    <s style=\"color:#B87533; opacity:0.9;\">\n      {{ v.compare_at_price | money }}\n    </s>\n  {%- endif -%}\n  <span>\n    {{ v.price | money }}\n  </span>\n</p>"}},"liquid_7fmcba":{"type":"liquid","settings":{"liquid":"{%- assign v = product.selected_or_first_available_variant -%}\n\n{%- if v.compare_at_price and v.compare_at_price > v.price -%}\n  {%- assign savings_cents = v.compare_at_price | minus: v.price -%}\n  <p class=\"sw-savings\">\n    {{ savings_cents | money_with_currency | replace: 'EUR', '' | strip }} euros d'économies\n  </p>\n{%- endif -%}"}},"liquid_pP9EHX":{"type":"liquid","settings":{"liquid":"{%- assign p = all_products['loperateur'] -%}\n{%- if p -%}\n\n  {%- assign v = p.selected_or_first_available_variant -%}\n\n  {%- assign mo = nil -%}\n\n  {%- if v and v.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = v.metafields.custom.buy_button.value -%}\n  {%- elsif p.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = p.metafields.custom.buy_button.value -%}\n  {%- endif -%}\n\n  {%- if mo -%}\n    {%- render 'meta-buy-button', mo: mo, force_label: 'Commencer le programme' -%}\n  {%- else -%}\n    <!-- buy_button introuvable (ni sur la variante, ni sur le produit) -->\n  {%- endif -%}\n\n{%- else -%}\n  <!-- Produit introuvable -->\n{%- endif -%}"}}},"block_order":["heading_pjbK3T","text_7W3cwK","liquid_wExkQQ","liquid_7fmcba","liquid_pP9EHX"],"name":"t:sections.image-with-text-overlay.name","settings":{"transparent_header":false,"image":"shopify://shop_images/background_formation.png","image_height":"900px","content_width":"small","content_position":"md:items-center md:justify-start","text_alignment":"left","image_height_mobile":"auto","content_position_mobile":"items-end justify-start","text_alignment_mobile":"left","color_text":"#ffffff","color_background":"","gradient_background":"","color_highlight":"#b87533","gradient_highlight":"","color_button_text":"#171717","color_button_background":"#b87533","color_button_gradient":"","color_overlay":"#171717","overlay_opacity":60,"padding_top":0,"padding_bottom":0,"divider":false,"full_width":true,"rounded":false,"enable_parallax":true,"parallax_direction":"vertical"}},"product-recommendations":{"type":"product-recommendations","settings":{"product_limit":3,"columns":3,"carousel_on_desktop":true,"columns_mobile":"1","swipe_on_mobile":true,"heading":"<strong>Continue ton apprentissage</strong>","heading_size":"title-md","heading_alignment":"text-left md:items-end md:flex-row","heading_tag":"h2","subheading":"","description":"","highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":88,"padding_bottom":88,"divider":false,"full_width":false,"rounded":true}},"recently-viewed":{"type":"recently-viewed","settings":{"product_limit":6,"columns":4,"carousel_on_desktop":true,"columns_mobile":"1","swipe_on_mobile":true,"heading":"Vus récemment","heading_size":"title-md","heading_alignment":"text-left md:items-end md:flex-row","heading_tag":"h2","subheading":"","description":"","highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"","gradient_b