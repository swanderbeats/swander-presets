ighlighted_reveal":false},"blocks":{}},"text_YHXXxE":{"type":"text","name":"t:blocks.text.name","settings":{"text":"<p>Tu sais peut-être déjà assembler des sons ensembles, mais tu n'as pas la sensation de réussir à <strong>mettre tes émotions dans ta musique... </strong>Le Compositeur te donne les deux piliers fondamentaux d’un morceau fort : <strong>comprendre la théorie musicale sans solfège inutile</strong>, et apprendre à <strong>structurer un morceau pour qu’il raconte quelque chose</strong>. Ici, tu ne composes plus au hasard : tu crées avec intention.</p>","text_font":"body","text_size":"text-base","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"width":"fit-content","custom_width":100,"alignment":"left","width_mobile":"fit-content","custom_width_mobile":100,"effects":"none","highlighted_text":"text","highlighted_scribble":"circle"},"blocks":{}},"video_CXFEDN":{"type":"video","name":"t:blocks.video.name","settings":{"source":"uploaded","video":"shopify://files/videos/Wesbite - Présentation - Le Compositeur.mp4","video_url":"https://www.youtube.com/watch?v=_9VUPq3SxOc","description":"","aspect_ratio":"adapt","enable_video_autoplay":false,"enable_video_looping":true,"source_mobile":"uploaded","video_mobile":"shopify://files/videos/Wesbite - Présentation - Le Compositeur.mp4","video_url_mobile":"","description_mobile":"","aspect_ratio_mobile":"adapt","width":"fill","custom_width":100,"width_mobile":"fill","custom_width_mobile":100,"border":"none","border_width":1,"border_opacity":100,"border_radius":0},"blocks":{}},"spacer_8amLGJ":{"type":"spacer","name":"t:blocks.spacer.name","settings":{"size":"percent","percent_size":100,"pixel_size":120,"custom_mobile_size":false,"size_mobile":"percent","percent_size_mobile":100,"pixel_size_mobile":120},"blocks":{}},"custom_liquid_pLCaqA":{"type":"custom-liquid","name":"t:sections.custom-liquid.name","settings":{"liquid":"<h2 style=\"\n  font-size: 18px;\n  font-weight: bold;\n\">\n  CE QUE TU VAS APPRENDRE : \n</h2>"},"blocks":{}},"spacer_Mrxp8q":{"type":"spacer","name":"t:blocks.spacer.name","disabled":true,"settings":{"size":"percent","percent_size":100,"pixel_size":120,"custom_mobile_size":false,"size_mobile":"percent","percent_size_mobile":100,"pixel_size_mobile":120},"blocks":{}},"text_FDwKdW":{"type":"text","name":"t:blocks.text.name","settings":{"text":"<p>• <strong>Comprendre réellement les intervalles, gammes et accords</strong> (sans passer par le solfège traditionnel)<br/>• Éviter les fausses notes et composer avec cohérence<br/>• Construire des <strong>progressions d’accords émotionnelles</strong><br/>• Harmoniser une mélodie intelligemment<br/>• Composer des mélodies qui reposent sur une base solide<br/>• Structurer un morceau pour créer <strong>tension, contraste et relâchement</strong><br/>• Transformer une simple idée en <strong>track construite</strong><br/>• Gérer les transitions et variations sans casser l’énergie<br/>• Créer des morceaux qui racontent quelque chose<br/>• <strong>Produire avec une vision claire</strong> au lieu d’empiler des pistes</p>","text_font":"body","text_size":"text-base","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"width":"fit-content","custom_width":100,"alignment":"left","width_mobile":"fit-content","custom_width_mobile":100,"effects":"none","highlighted_text":"text","highlighted_scribble":"circle"},"blocks":{}},"spacer_FYBerF":{"type":"spacer","name":"t:blocks.spacer.name","settings":{"size":"percent","percent_size":100,"pixel_size":120,"custom_mobile_size":false,"size_mobile":"percent","percent_size_mobile":100,"pixel_size_mobile":120},"blocks":{}},"custom_liquid_fdxk9q":{"type":"custom-liquid","name":"t:sections.custom-liquid.name","settings":{"liquid":"<h2 style=\"\n  font-size: 18px;\n  font-weight: bold;\n\">\n  POUR TOI SI \n</h2>"},"blocks":{}},"spacer_QXM8cr":{"type":"spacer","name":"t:blocks.spacer.name","disabled":true,"settings":{"size":"percent","percent_size":100,"pixel_size":120,"custom_mobile_size":false,"size_mobile":"percent","percent_size_mobile":100,"pixel_size_mobile":120},"blocks":{}},"text_xBdbRX":{"type":"text","name":"t:blocks.text.name","settings":{"text":"<p>✓ Tu veux comprendre <strong>pourquoi certaines prods te touchent vraiment</strong><br/>✓ Tu composes “à l’oreille” mais tu veux <strong>plus de contrôle sur tes accords et tes mélodies</strong><br/>✓ Tu bloques sur <strong>l’harmonie, les progressions d’accords ou les tonalités</strong><br/>✓ Tu veux structurer tes morceaux de manière <strong>plus professionnelle et cohérente</strong><br/>✓ Tu veux créer <strong>plus d’émotion</strong> sans complexifier inutilement<br/>✓ Tu veux composer avec <strong>intention et clarté</strong></p>","text_font":"body","text_size":"text-base","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"width":"fit-content","custom_width":100,"alignment":"left","width_mobile":"fit-content","custom_width_mobile":100,"effects":"none","highlighted_text":"text","highlighted_scribble":"circle"},"blocks":{}},"spacer_3DjH7p":{"type":"spacer","name":"t:blocks.spacer.name","settings":{"size":"percent","percent_size":100,"pixel_size":120,"custom_mobile_size":false,"size_mobile":"percent","percent_size_mobile":100,"pixel_size_mobile":120},"blocks":{}},"custom_liquid_kCeKh4":{"type":"custom-liquid","name":"t:sections.custom-liquid.name","settings":{"liquid":"<h2 style=\"\n  font-size: 18px;\n  font-weight: bold;\n  color: #ff3b3b;\n\">\n  PAS POUR TOI SI :\n</h2>"},"blocks":{}},"spacer_Cmy7mX":{"type":"spacer","name":"t:blocks.spacer.name","disabled":true,"settings":{"size":"percent","percent_size":100,"pixel_size":120,"custom_mobile_size":false,"size_mobile":"percent","percent_size_mobile":100,"pixel_size_mobile":120},"blocks":{}},"text_4ierfF":{"type":"text","name":"t:blocks.text.name","settings":{"text":"<p>✗