ent_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":88,"padding_bottom":88,"divider":false,"narrow":true,"rounded":false}},"testimonials_8ERKtF":{"type":"testimonials","blocks":{"testimonial_48NWLm":{"type":"testimonial","settings":{"icon":"quote","text":"<p>Add customer reviews and testimonials to showcase your store’s happy customers.</p>","author":"Author's name","author_info":"","author_url":"","image_ratio":"rounded","image_height":30,"highlighted_text":"none","highlighted_scribble":"circle"}},"testimonial_4qmgQm":{"type":"testimonial","settings":{"icon":"quote","text":"<p>Add customer reviews and testimonials to showcase your store’s happy customers.</p>","author":"Author's name","author_info":"","author_url":"","image_ratio":"rounded","image_height":30,"highlighted_text":"none","highlighted_scribble":"circle"}},"testimonial_krhg8P":{"type":"testimonial","settings":{"icon":"quote","text":"<p>Add customer reviews and testimonials to showcase your store’s happy customers.</p>","author":"Author's name","author_info":"","author_url":"","image_ratio":"rounded","image_height":30,"highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["testimonial_48NWLm","testimonial_4qmgQm","testimonial_krhg8P"],"name":"t:sections.testimonials.name","settings":{"heading":"","heading_size":"title-md","heading_alignment":"text-center md:items-center","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":0,"padding_bottom":0,"divider":false,"rounded":false}},"image_with_text_yJHbyt":{"type":"image-with-text","blocks":{"heading_zKDTNi":{"type":"heading","settings":{"heading":"<strong>Ton formateur</strong>","heading_size":"title-md","heading_tag":"h2","highlighted_text":"half_text","highlighted_scribble":"circle","highlighted_reveal":true}},"text_ydDD6A":{"type":"text","settings":{"text":"<p>Je suis Swander — musicien, beatmaker et ingénieur du son depuis plus d’une décennie. </p><p>J’ai commencé la guitare quand j’étais jeunr et, depuis, j’ai composé des <strong>milliers de morceaux</strong> dans des styles très différents.<br/><br/>Avec le temps, j’ai appris à comprendre les mécanismes de l’harmonie, à les tester, les déconstruire, puis les simplifier <strong>pour les rendre réellement utiles à la création. </strong></p><p>Depuis novembre 2024, j’ai accompagné des <strong>dizaines d’élèves en cours particuliers</strong>, et j’ai retrouvé les mêmes problématiques de composition : comment enchaîner ses idées, enrichir un arrangement sans tout compliquer, éviter les fausses notes, sortir d’une boucle interminable...<br/><br/>Et surtout, j’ai trouvé <strong>des solutions concrètes pour y répondre.</strong><br/><br/><strong>Le Compositeur</strong> est né exactement de ça. Ce programme n’a pas été conçu pour faire de toi un théoricien, mais pour t’aider à composer avec intention, comprendre ce que tu fais et <strong>t'exprimer entièrement sans jamais être frustré</strong><br/><br/>Plusieurs heures de contenu clair et structuré, pensé pour débloquer ta créativité et t’aider à avancer dans ta musique — sans jargon inutile, sans solfège académique hors contexte, et <strong>sans perdre ton temps.</strong><br/><br/><strong>Le Compositeur</strong> n'empile pas juste des notes,<strong> il organise ses émotions</strong> dans le temps. </p><p>Peut-être que demain, <strong>ce sera toi, le Compositeur.</strong></p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"underline","highlighted_scribble":"circle"}},"liquid_7czmNh":{"type":"liquid","settings":{"liquid":"{%- assign p = all_products['le-compositeur'] -%}\n{%- if p -%}\n\n  {%- assign v = p.selected_or_first_available_variant -%}\n\n  {%- assign mo = nil -%}\n\n  {%- if v and v.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = v.metafields.custom.buy_button.value -%}\n  {%- elsif p.metafields.custom.buy_button.value != blank -%}\n    {%- assign mo = p.metafields.custom.buy_button.value -%}\n  {%- endif -%}\n\n  {%- if mo -%}\n    {%- render 'meta-buy-button', mo: mo, force_label: 'Commencer le programme' -%}\n  {%- else -%}\n    <!-- buy_button introuvable (ni sur la variante, ni sur le produit) -->\n  {%- endif -%}\n\n{%- else -%}\n  <!-- Produit introuvable -->\n{%- endif -%}"}}},"block_order":["heading_zKDTNi","text_ydDD6A","liquid_7czmNh"],"custom_css":["/* Stop le zoom \"artificiel\" du thème */.image-with-text img,.image-with-text__media img,.image-with-text .media img {transform: none !important;}"],"name":"t:sections.image-with-text.name","settings":{"image":"shopify://shop_images/website_assets_qui_suis_je_formation.gif","image_height":"adapt","image_width":"small","layout":"text_first","text_alignment":"left","content_position":"align-self-center","image_height_mobile":"auto","text_alignment_mobile":"left","color_text":"","color_background":"#1e1e1e","gradient_background":"","color_background_2":"","gradient_background_2":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":88,"padding_bottom":88,"divider":false,"full_width":false,"rounded":true,"enable_parallax":true,"parallax_direction":"vertical"}},"faq_BgGDJU":{"type":"faq","blocks":{"question_bGw4M8":{"type":"question","settings":{"title":"Puis-je suivre ce programme sans faire de sound design avancé ?","text":"<p>Oui. L'objectif n'est pas de te transformer en sound designer, mais de te rendre autonome sur l'outil et la production.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_dFdndB":{"type":"question","settings":{"title":"Quelle est la différence entre acheter séparément et prendre L'Opérateur ?","text":"<p>En achetant le bundle, tu as l'ensemble pour 397 € au lieu de 494 € (valeur catalogue).</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_KK6kJb":{"type":"question","settings":{"title":"Combien de leçons contient le bundle L'Opérateur ?","text":"<p>84 leçons au total.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_CxXyQe":{"type":"question","settings":{"title":"Combien d'heures de contenu vidéo contient L'Opérateur ?","text":"<p>22h19 de vidéo au total.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_xDccDV":{"type":"question","settings":{"title":"Les méthodes de Production Master fonctionnent-elles en rap, house, techno, pop...?c'est","text":"<p>Oui. Les concepts sont universels : hiérarchie, énergie, contraste, transitions, cohérence.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_hwM9YU":{"type":"question","settings":{"title":"Est-ce que ce programme aide vraiment à finir ses morceaux ?","text":"<p>Oui. Production Master est centré sur la structure, l'énergie, les variations et le passage de la loop au morceau.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_kp8MtF":{"type":"question","settings":{"title":"Est-ce une formation Ableton Live orientée instruments et effets natifs ?","text":"<p>Oui. Le programme est conçu pour exploiter les outils natifs (instruments + effets) plutôt que dépendre de plugins tiers.</p>","highlighted_text":"none","highlighted_scribble":"circle"}},"question_9AghEx":{"type":"question","settings":{"title":"L'Opérateur est-il adapté aux débutants sur Ableton Live ?","text":"<p>Oui. Ableton Master reprend les bases et t'amène progressivement vers un usage solide et autonome.</p>","highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["question_bGw4M8","question_dFdndB","question_KK6kJb","question_CxXyQe","question_xDccDV","question_hwM9YU","question_kp8MtF","question_9AghEx"],"custom_css":[],"name":"t:sections.faq.name","settings":{"style":"with-background","heading":"Questions fréquentes","heading_size":"title-md","heading_alignment":"text-left md:items-end md:flex-row","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","color_overlay":"#ffffff","overlay_opacity":4,"padding_top":0,"padding_bottom":0,"divider":false,"narrow":false,"rounded":false}},"image_with_text_overlay_dnpBHr":{"type":"image-with-text-overlay","blocks":{"heading_pjbK3T":{"type":"heading","settings":{"heading":"<strong>Et si ton vrai problème, c’était juste </strong><em><strong>ton environnement ?</strong></em>","heading_size":"title-sm","heading_tag":"p","highlighted_text":"underline","highlighted_scribble":"circle","highlighted_reveal":false}},"text_7W3cwK":{"type":"text","settings":{"text":"<p>Si la technique sans émotion ne te suffit plus, et que tu as envie d'en insuffler dans ta musique,   <strong>Le Compositeur t’aide à relier les deux</strong> : comprendre l’harmonie pour créer du sens, et structurer ton morceau pour que ce sens traverse l’écoute du début à la fin.</p><p>Si tu veux que tes morceaux commencent à raconter quelque chose, ton chemin démarre ici.</p><p>Entre dans la peau du Compositeur.</p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"scr