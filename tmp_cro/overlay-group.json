{
  "name": "t:sections.overlay-group.name",
  "type": "custom.overlay",
  "sections": {
    "cart-drawer": {
      "type": "cart-drawer",
      "custom_css": [
        ":where( #CartDrawer .drawer__inner, #CartDrawer .drawer__content, .cart-drawer .drawer__inner, .cart-drawer .drawer__content, cart-drawer .drawer__inner, cart-drawer .drawer__content, dialog[id*=\"Cart\"] > *, dialog[id*=\"cart\"] > * ) {border-left: 1px solid #ffffff !important; box-shadow: -10px 0 30px rgba(184, 117, 51, 0.15) !important;}"
      ],
      "settings": {
        "show_vendor": false,
        "show_cart_note": false,
        "show_shipping_calculator": false,
        "add_discount_code": true,
        "show_view_cart_button": false,
        "show_checkout_button": true,
        "show_free_shipping_bar": false,
        "free_shipping_minimum_amount": "1000",
        "cart_recommendations_enabled": true,
        "cart_recommendations_heading": "Vous pourriez aussi aimer",
        "cart_recommendations_limit": 5,
        "show_cart_recommendations_vendor": false,
        "show_cart_recommendations_price": true,
        "cart_recommendations_products": [],
        "empty_cart_message": "",
        "empty_cart_collections": [],
        "recent_products_enabled": true,
        "recent_products_heading": "Vus récemment",
        "recent_products_limit": 5,
        "show_recent_products_vendor": false,
        "show_recent_products_price": true
      }
    },
    "search-drawer": {
      "type": "search-drawer",
      "disabled": true,
      "settings": {}
    },
    "newsletter-popup": {
      "type": "newsletter-popup",
      "blocks": {
        "text-1": {
          "type": "text",
          "settings": {
            "text": "<p>FIRST TIMER?</p>",
            "text_font": "body",
            "text_size": "subtext-custom",
            "text_max_size": 12,
            "text_line_height": 1.6,
            "text_letter_spacing": 0,
            "text_capitalize": false,
            "secondary_color": true,
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Sign up and get <em>20% off</em> your first order",
            "heading_size": "text-2xl lg:text-3xl",
            "heading_tag": "h2",
            "highlighted_text": "scribble",
            "highlighted_scribble": "basic-underline",
            "highlighted_reveal": false
          }
        },
        "spacing": {
          "type": "spacing",
          "settings": {
            "height": 32,
            "height_mobile": 12
          }
        },
        "form": {
          "type": "form",
          "settings": {}
        },
        "text-2": {
          "type": "text",
          "settings": {
            "text": "<p>Subscribe to our newsletter and be the first to hear about our new arrivals, special promotions and online exclusives.</p>",
            "text_font": "body",
            "text_size": "text-sm",
            "text_max_size": 32,
            "text_line_height": 1.6,
            "text_letter_spacing": 0,
            "text_capitalize": false,
            "secondary_color": true,
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "media": {
          "type": "media",
          "settings": {}
        },
        "floating": {
          "type": "floating",
          "settings": {
            "heading": "Get 20% Off",
            "content_position": "left-0",
            "show_social": true,
            "mobile_disabled": true,
            "mobile_hide_social": false,
            "color_text": "#171717",
            "color_background": "#ffffff"
          }
        }
      },
      "block_order": [
        "text-1",
        "heading",
        "spacing",
        "form",
        "text-2",
        "media",
        "floating"
      ],
      "disabled": true,
      "settings": {
        "mode": "enabled",
        "only_homepage": true,
        "only_visitor": true,
        "delay": 7,
        "expiry": 30,
        "text_alignment": "left",
        "content_position": "right-0",
        "color_drawer_text": "#171717",
        "color_drawer_background": "#ffffff",
        "color_drawer_highlight": "#ffddbf",
        "color_drawer_button_text": "#ffffff",
        "color_drawer_button_background": "#171717",
        "color_drawer_button_gradient": "",
        "color_drawer_overlay": "#171717"
      }
    },
    "age-verifier": {
      "type": "age-verifier",
      "blocks": {
        "image": {
          "type": "image",
          "settings": {
            "image_width": "custom",
            "image_max_width": 70,
            "image_max_width_mobile": 70
          }
        },
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Confirm your age",
            "heading_size": "text-lg-2xl",
            "heading_tag": "h2",
            "highlighted_text": "none",
            "highlighted_scribble": "circle",
            "highlighted_reveal": false
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Are you 18 years old or older?</p>",
            "text_font": "body",
            "text_size": "text-base",
            "text_max_size": 32,
            "text_line_height": 1.6,
            "text_letter_spacing": 0,
            "text_capitalize": false,
            "secondary_color": false,
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "spacing": {
          "type": "spacing",
          "settings": {
            "height": 16,
            "height_mobile": 12
          }
        },
        "buttons": {
          "type": "buttons",
          "settings": {
            "button_label_1": "Yes, I am",
            "button_label_2": "No, I'm not",
            "button_link_2": "",
            "button_external_2": false
          }
        }
      },
      "block_order": [
        "image",
        "heading",
        "text",
        "spacing",
        "buttons"
      ],
      "disabled": true,
      "settings": {
        "mode": "enabled",
        "expiry": 30,
        "text_alignment": "center",
        "content_position": "center-0",
        "blur_background_image": false,
        "color_drawer_text": "#171717",
        "color_drawer_background": "#ffffff",
        "color_drawer_highlight": "#ffddbf",
        "color_drawer_button_text": "#ffffff",
        "color_drawer_button_background": "#171717",
        "color_drawer_button_gradient": "",
        "color_drawer_overlay": "#171717"
      }
    },
    "cookie-banner": {
      "type": "cookie-banner",
      "blocks": {
        "image": {
          "type": "image",
          "settings": {
            "image_width": "custom",
            "image_max_width": 40,
            "image_max_width_mobile": 40
          }
        },
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Cookies",
            "heading_size": "text-lg-2xl",
            "heading_tag": "h2",
            "highlighted_text": "none",
            "highlighted_scribble": "circle",
            "highlighted_reveal": false
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Ce site utilise des cookies pour améliorer ton expérience de navigation.</p>",
            "text_font": "body",
            "text_size": "text-base",
            "text_max_size": 32,
            "text_line_height": 1.6,
            "text_letter_spacing": 0,
            "text_capitalize": false,
            "secondary_color": false,
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "spacing": {
          "type": "spacing",
          "settings": {
            "height": 16,
            "height_mobile": 12
          }
        },
        "buttons": {
          "type": "buttons",
          "settings": {
            "button_label_1": "Accepter",
            "button_label_2": "Refuser"
          }
        }
      },
      "block_order": [
        "image",
        "heading",
        "text",
        "spacing",
        "buttons"
      ],
      "settings": {
        "mode": "enabled",
        "delay": 2,
        "text_alignment": "center",
        "content_position": "left-0",
        "color_drawer_text": "#FFFFFF",
        "color_drawer_background": "#181818",
        "color_drawer_highlight": "#B87533",
        "color_drawer_button_text": "#FFFFFF",
        "color_drawer_button_background": "#B87533",
        "color_drawer_button_gradient": ""
      }
    },
    "mobile-dock": {
      "type": "mobile-dock",
      "blocks": {
        "mobile-dock-1": {
          "type": "home",
          "settings": {
            "custom_icon": "",
            "title": "Home"
          }
        },
        "mobile-dock-2": {
          "type": "menu",
          "settings": {
            "custom_icon": "",
            "title": "Menu"
          }
        },
        "mobile-dock-3": {
          "type": "search",
          "settings": {
            "custom_icon": "",
            "title": "Search"
          }
        },
        "mobile-dock-4": {
          "type": "link",
          "settings": {
            "custom_icon": "",
            "title": "Shop",
            "link": "shopify://collections/all",
            "external": false
          }
        },
        "mobile-dock-5": {
          "type": "cart",
          "settings": {
            "custom_icon": "",
            "title": "Cart"
          }
        },
        "mobile-dock-6": {
          "type": "account",
          "settings": {
            "custom_icon": "",
            "title": "Account"
          }
        }
      },
      "block_order": [
        "mobile-dock-1",
        "mobile-dock-2",
        "mobile-dock-3",
        "mobile-dock-4",
        "mobile-dock-5",
        "mobile-dock-6"
      ],
      "disabled": true,
      "settings": {
        "color_text": "#000000",
        "color_background": "#ffffff",
        "gradient_background": "",
        "padding_top": 8,
        "padding_bottom": 8,
        "divider": true,
        "rounded": true
      }
    }
  },
  "order": [
    "cart-drawer",
    "search-drawer",
    "newsletter-popup",
    "age-verifier",
    "cookie-banner",
    "mobile-dock"
  ]
}